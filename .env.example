# RefundPilot AI — environment variables
#
# This single file documents every variable. Copy it to the two places that
# read it:
#   Backend : cp .env.example backend/.env
#   Frontend: cp .env.example frontend/.env.local   (only NEXT_PUBLIC_* is used)
#
# IMPORTANT: the app runs fully WITHOUT any of these. With no OPENAI_API_KEY it
# runs in deterministic mode (rule-based decision + templated reply).

# --- LLM (optional) --------------------------------------------------------
# If set, the agent uses the LLM ONLY to phrase the final reply. The refund
# decision itself is always made by the deterministic policy engine.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional: point at any OpenAI-compatible endpoint (e.g. a local proxy).
OPENAI_BASE_URL=

# --- Backend ---------------------------------------------------------------
# Override the SQLite file location (defaults to backend/refundpilot.db).
REFUNDPILOT_DB=

# --- Frontend --------------------------------------------------------------
# Where the Next.js app finds the FastAPI backend.
NEXT_PUBLIC_API_URL=http://localhost:8000
