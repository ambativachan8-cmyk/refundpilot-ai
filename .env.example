# RefundPilot AI — environment variables
#
# This single file documents every variable. Copy it to the two places that
# read it:
#   Backend : cp .env.example backend/.env
#   Frontend: cp .env.example frontend/.env.local   (only NEXT_PUBLIC_* is used)
#
# IMPORTANT: the app runs fully WITHOUT any of these. With no OPENAI_API_KEY it
# runs in deterministic mode (rule-based decision + templated reply).

# --- LLM (optional) --------------------------------------------------------
# The LLM is used ONLY for language understanding (message-intent / refund-intent
# classification) and to phrase simple replies. The deterministic policy engine
# always decides the refund outcome. The app runs fully without any LLM.
#
# Provider: auto | openai | ollama | none
#   auto   -> use OpenAI if a key is set, else local Ollama if reachable, else none
#   openai -> requires OPENAI_API_KEY
#   ollama -> local, no key, no internet (must have `ollama serve` running)
#   none   -> always deterministic
LLM_PROVIDER=auto

# OpenAI (cloud)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional: point at any OpenAI-compatible endpoint (e.g. a local proxy).
OPENAI_BASE_URL=

# Ollama (local). Install from https://ollama.com, then e.g. `ollama pull qwen2.5:3b`.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# Max seconds to wait for any LLM call before falling back to deterministic logic.
LLM_TIMEOUT_SECONDS=8

# Let the LLM rephrase reply templates. Off by default for demo speed — templates
# are already natural, and the LLM is still used for language understanding.
LLM_REPHRASE=false

# --- Backend ---------------------------------------------------------------
# Override the SQLite file location (defaults to backend/refundpilot.db).
REFUNDPILOT_DB=

# --- Frontend --------------------------------------------------------------
# Where the Next.js app finds the FastAPI backend.
NEXT_PUBLIC_API_URL=http://localhost:8000
